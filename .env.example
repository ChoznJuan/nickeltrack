# NickelTrack environment configuration
# -------------------------------------
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
# chmod 600 .env
#
# The systemd unit on the LXC container reads this via `EnvironmentFile=-/opt/nickeltrack/.env`
# (the `-` prefix means "ignore if missing"). The `bootstrap_app.sh` script will copy
# this file to `.env` automatically on first deploy.
#
# IMPORTANT: Never commit a real `.env` to git. It's in `.gitignore`.

# Postgres connection — single DSN form (preferred)
# Format: postgresql://USER:PASS@HOST:PORT/DBNAME
MEMORY_DB_URL=postgresql://USER:PASS@HOST:5432/DBNAME

